# Brewfile — Homebrew formulae, casks, and taps for this machine.
#
# This file is the source of truth for `brew bundle`. It lists only packages
# installed *on request* (not their dependencies), so it stays readable.
#
#   Install everything:    brew bundle --file=~/.dotfiles/brew/Brewfile
#   Check what's missing:  brew bundle check --file=~/.dotfiles/brew/Brewfile
#   Regenerate this file:  brew bundle dump --file=~/.dotfiles/brew/Brewfile --force
#   Remove anything not listed here: brew bundle cleanup --file=~/.dotfiles/brew/Brewfile

