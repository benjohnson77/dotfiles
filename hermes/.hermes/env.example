# Hermes secrets — template. Copy to ~/.hermes/.env and fill in real values.
#   cp ~/.dotfiles/hermes/.hermes/env.example ~/.hermes/.env
# The real ~/.hermes/.env is gitignored and MUST NOT be committed.
# See ../../SECRETS.md for where to obtain each value.

# ─── Core LLM (Anthropic) ───────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_TOKEN=

# ─── Additional model providers (also referenced in config.yaml) ────
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=

# ─── Browser automation (Browserbase) ───────────────────────────────
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ─── MCP servers ────────────────────────────────────────────────────
FIGMA_API_KEY=

# ─── Optional: Bitwarden Secrets Manager (config.yaml secrets.bitwarden) ─
# BWS_ACCESS_TOKEN=

# ─── Non-secret runtime toggles (safe defaults; adjust as desired) ──
HERMES_MAX_ITERATIONS=
BROWSER_SESSION_TIMEOUT=
BROWSER_INACTIVITY_TIMEOUT=
TERMINAL_TIMEOUT=
TERMINAL_LIFETIME_SECONDS=
